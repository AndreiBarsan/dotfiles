{
  "autoDocstring.docstringFormat": "google",
  "editor.renderWhitespace": "all",
  "breadcrumbs.enabled": true,
  "editor.mouseWheelZoom": true,
  "editor.guides.bracketPairs": true,
  "editor.rulers": [
    80,
    120
  ],
  "files.trimTrailingWhitespace": true,
  "files.watcherExclude": {
    "**/bazel-av": true,
    "**/bazel-bin": true,
    "**/bazel-out": true,
    "**/bazel-testlogs": true,
    "**/outputs": true,
    "**/.trunk/*out": true,
    "**/.trunk/*out/": true,
    "**/.trunk/*actions/": true,
    "**/.trunk/*logs/": true,
    "**/.trunk/*plugins/": true,
    "**/.trunk/*notifications/": true
  },
  "gitlens.currentLine.enabled": false,
  "gitlens.hovers.currentLine.over": "line",
  "importMagic.maxColumns": 120,
  "latex-workshop.intellisense.package.enabled": true,
  "latex-workshop.intellisense.optionalArgsEntries.enabled": false,
  "latex-workshop.intellisense.unimathsymbols.enabled": true,
  "latex-workshop.latex.autoBuild.interval": 330,
  "latex-workshop.latex.autoBuild.run": "onSave",
  "python.linting.pylintEnabled": false,
  "remote.SSH.showLoginTerminal": true,
  "telemetry.telemetryLevel": "off",
  "custom.commands": [
    {
      "command": "extension.openBuildFile",
      "callback": "extension.openBuildFile"
    }
  ],
  // Vim crap goes last since it's a whole separate thing.
  "vim.easymotion": true,
  "vim.sneak": true,
  "vim.incsearch": true,
  "vim.useSystemClipboard": true,
  "vim.useCtrlKeys": true,
  "vim.hlsearch": true,
  "vim.insertModeKeyBindings": [
    {
      "before": [
        "j",
        "j"
      ],
      "after": [
        "<Esc>"
      ]
    }
  ],
  "vim.textwidth": 120,
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": [
        "<leader>",
        "d"
      ],
      "after": [
        "d",
        "d"
      ]
    },
    {
      "before": [
        "<C-n>"
      ],
      "commands": [
        ":nohl"
      ]
    },
    {
      "before": [
        ";"
      ],
      "after": [
        ":"
      ]
    },
    {
      "before": [
        ":"
      ],
      "after": [
        ";"
      ]
    },
    {
      "before": [
        "<C-h>"
      ],
      "after": [
        "<C-w>",
        "h"
      ]
    },
    {
      "before": [
        "<C-l>"
      ],
      "after": [
        "<C-w>",
        "l"
      ]
    },
    {
      "before": [
        "<C-j>"
      ],
      "after": [
        "<C-w>",
        "j"
      ]
    },
    {
      "before": [
        "<C-k>"
      ],
      "after": [
        "<C-w>",
        "k"
      ]
    },
    {
      "before": [
        "<space>"
      ],
      "after": [
        "<C-p>"
      ]
    }
  ],
  "vim.leader": ",",
  "vim.handleKeys": {
    "<C-a>": false,
    "<C-f>": false
  },
  "workbench.iconTheme": "vscode-icons",
  "terminal.integrated.rendererType": "dom",
  "editor.glyphMargin": false,
  "editor.smoothScrolling": true,
  "editor.cursorSurroundingLines": 5,
  "editor.minimap.enabled": false,
  "workbench.editorAssociations": {
    "*.ipynb": "jupyter-notebook"
  },
  "cSpell.userWords": [
