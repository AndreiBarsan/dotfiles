  "emmet.showSuggestionsAsSnippets": true,
  "editor.suggestSelection": "first",
  "vsintellicode.modify.editor.suggestSelection": "automaticallyOverrodeDefaultValue",
  "notebook.cellToolbarLocation": {
    "default": "right",
    "jupyter-notebook": "left"
  },
  "explorer.confirmDragAndDrop": false,
  "github.copilot.enable": {
    "*": true,
    "plaintext": true,
    "markdown": false,
    "scminput": false,
    "yaml": true,
    "python": true,
    "rust": true,
    "latex": false,
    "proto3": true,
    "csv": false,
    "html": false
  },
  "git.autofetch": true,
  "redhat.telemetry.enabled": false,
  "yaml.format.enable": false,
  "yaml.format.printWidth": 120,
  "cSpell.minWordLength": 3,
  "editor.suggest.showInlineDetails": false,
  "editor.inlineSuggest.enabled": true,
  "trunk.trunkInlineDecoratorsDisabled": true,
  "trunk.inlineDecorators": false,
  "trunk.trunkGrayOutNonBlockingIssues": false,
  "editor.fontSize": 11.5,
  // "editor.fontSize": 14,
  "files.exclude": {
    "**/bazel-av": true,
    "**/bazel-bin": true,
    "**/bazel-out": true,
    "**/bazel-testlogs": true,
    "**/outputs": true,
    "**/.trunk/*out": true,
    "**/.trunk/*out/": true,
    "**/.trunk/*actions/": true,
    "**/.trunk/*logs/": true,
    "**/.trunk/*plugins/": true,
    "**/.trunk/*notifications/": true
  },
  "python.linting.ignorePatterns": [
    "**/site-packages/**/*.py",
    ".vscode/*.py",
    "bazel-av/",
    "bazel-av2/",
    "bazel-bin/",
    "bazel-out/",
    "bazel-testlogs/",
    ".git/",
    ".ipynb_checkpoints/"
  ],
  "cSpell.enableFiletypes": [
    "BUILD",
    "Starlark",
    "proto3",
    "rust",
    "starlark"
  ],
  "cSpell.enabled": true,
  "cSpell.maxNumberOfProblems": 1000,
  "jupyter.interactiveWindow.textEditor.executeSelection": true,
  "remote.SSH.remoteServerListenOnSocket": true,
  "remote.SSH.remotePlatform": {
    "wb": "linux",
    "abarsan-dev-environment": "linux"
  },
  "jupyter.askForKernelRestart": false,
  "notebook.output.scrolling": true,
  "git.openRepositoryInParentFolders": "never",
  "notebook.lineNumbers": "on",
  "todohighlight.include": [
    "**/*.py",
    "**/*.ipynb",
    "**/*.sh",
    "**/*.rs",
    "**/*.js",
    "**/*.jsx",
    "**/*.ts",
    "**/*.tsx",
    "**/*.html",
    "**/*.php",
    "**/*.css",
    "**/*.scss"
  ],
  "todohighlight.keywords": [
    "TODO",
    "XXX",
    "FIXME",
    "NOTE",
  ],
  "prettier.enable": false,
  "terminal.integrated.persistentSessionScrollback": 5000,
  "terminal.integrated.scrollback": 1000000,
  "go.toolsManagement.autoUpdate": true,
  "trunk.showPreexistingIssues": false,
  "editor.accessibilitySupport": "off",
  "cmake.showOptionsMovedNotification": false,
  "editor.formatOnSave": true,
  "[bend]": {
    "editor.tabSize": 2
  },
  "github.copilot.editor.enableAutoCompletions": true,
  "githubPullRequests.pullBranch": "never",
  "workbench.colorTheme": "Default Light Modern",
  "git.blame.editorDecoration.enabled": false,
  "workbench.editor.empty.hint": "hidden",
  "terminal.integrated.defaultProfile.linux": "zsh",
  "github.copilot.chat.codesearch.enabled": true,
  "mcp": {
    "servers": {}
  },
  "python.analysis.typeCheckingMode": "standard",
  "window.commandCenter": false,
  "workbench.layoutControl.enabled": false,
  "chat.tools.terminal.autoApprove": {
    "rm": false,
    "rmdir": false,
    "del": false,
    "kill": false,
    "curl": false,
    "wget": false,
    "eval": false,
    "chmod": true,
    "chown": false,
    "bazel": true,
    "trunk": true,
    "sed": true,
    "tools/trunk": true,
    "tools/memray": true,
    "tools/build_binary_deps.sh": true,
    "tools/generate_rust_project_file.sh": true,
    "tools/bazel": true,
    "./tools/bazel": true,
    "/^Remove-Item\\b/i": false
  },
  "chat.agent.maxRequests": 40,
  "github.copilot.chat.agent.thinkingTool": true,
  "chat.mcp.access": "all",
}
